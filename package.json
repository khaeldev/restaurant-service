{
  "name": "restaurant-service",
  "version": "1.0.0",
  "description": "restaurant-service",
  "scripts": {
    "localstack:up": "docker compose up -d localstack",
    "localstack:down": "docker compose down -v",
    "localstack:reset": "npm run localstack:down && npm run localstack:up && sleep 5 && npm run localstack:init",
    "localstack:clean": "docker rm -f restaurant-service-localstack && rm -rf .local/localstack",
    "localstack:restart": "docker rm -f restaurant-service-localstack && rm -rf .local/localstack && npm run localstack:up && sleep 15 && npm run deploy:local && sleep 5 && npm run seed:local",
    "deploy:local": "bash scripts/local/deploy-localstack.sh",
    "sls:info:local": "serverless info --stage local --region us-east-1 --param=OPENAI_API_KEY=1 --param=ANTHROPIC_API_KEY=1 --param=JWT_SECRET=1 --param=FARMERS_MARKET_API_URL=http://127.0.0.1:3000/dev/farmers-market/buy",
    "invoke:local": "AWS_ENDPOINT_URL=http://127.0.0.1:4566 AWS_REGION=us-east-1 AWS_ACCESS_KEY_ID=local AWS_SECRET_ACCESS_KEY=local serverless invoke -f",
    "dev:local": "DYNAMODB_ENDPOINT=http://127.0.0.1:4566 AWS_ACCESS_KEY_ID=local AWS_SECRET_ACCESS_KEY=local REGION=us-east-1 serverless offline start --stage dev --region us-east-1 --param=OPENAI_API_KEY=1 --param=ANTHROPIC_API_KEY=1 --param=JWT_SECRET=local-dev-secret-change-this --param=FARMERS_MARKET_API_URL=http://127.0.0.1:3000/dev/farmers-market/buy",
    "setup:local": "npm run localstack:up && sleep 5 && npm run deploy:local && sleep 5 && npm run seed:local",
    "pkg": "serverless package --stage dev --region us-east-1 --param=OPENAI_API_KEY=1 --param=ANTHROPIC_API_KEY=1 --param=JWT_SECRET=1 --param=FARMERS_MARKET_API_URL=http://127.0.0.1:3000/dev/farmers-market/buy",
    "deploy": "serverless deploy --stage dev --region us-east-1 && npm run seed:dev",
    "deploy:prod": "serverless deploy --stage prod --region us-east-1 && npm run seed:prod",
    "seed:dev": "serverless invoke -f seedData --stage dev --region us-east-1",
    "seed:local": "serverless invoke -f seedData --stage local --region us-east-1 --param=OPENAI_API_KEY=local --param=ANTHROPIC_API_KEY=local --param=JWT_SECRET=local-dev-secret-change-this --param=FARMERS_MARKET_API_URL=http://127.0.0.1:4566/local/farmers-market/buy",
    "seed:prod": "serverless invoke -f seedData --stage prod --region us-east-1",
    "seed": "npm run seed:dev",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest --ci --detectOpenHandles --config=jest.config.json --passWithNoTests",
    "test:dev": "npm run lint --fix && npx jest --detectOpenHandles --config=jest.config.json --watch",
    "test:bdd:api": "API_BASE_URL=http://127.0.0.1:4566/restapis/al5rla3meb/local/_user_request_ npm run test:bdd 2>&1",
    "test:bdd": "TS_NODE_PROJECT=bdd/tsconfig.json cucumber-js --config cucumber.cjs --tags \"@smoke\"",
    "test:bdd:integration": "TS_NODE_PROJECT=bdd/tsconfig.json cucumber-js --config cucumber.cjs --tags \"@integration\"",
    "test:bdd:integration:verbose": "BDD_VERBOSE=1 TS_NODE_PROJECT=bdd/tsconfig.json cucumber-js --config cucumber.cjs --tags \"@integration\"",
    "test:bdd:integration:local": "API_BASE_URL=http://127.0.0.1:3000/dev TS_NODE_PROJECT=bdd/tsconfig.json cucumber-js --config cucumber.cjs --tags \"@integration\"",
    "test:bdd:all": "TS_NODE_PROJECT=bdd/tsconfig.json cucumber-js --config cucumber.cjs",
    "prepare": "husky",
    "logs:fc": "serverless logs --stage dev --region us-east-1 --function"
  },
  "engines": {
    "node": "22.19.0"
  },
  "devDependencies": {
    "@aws-sdk/types": "3.973.6",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@cucumber/cucumber": "12.7.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/aws-lambda": "8.10.161",
    "@types/jest": "30.0.0",
    "@types/node": "25.3.5",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "dotenv": "17.4.1",
    "esbuild": "0.27.7",
    "eslint": "10.0.2",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "serverless": "4.33.3",
    "serverless-localstack": "1.4.0",
    "serverless-offline": "14.5.0",
    "serverless-prune-plugin": "2.1.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.32.0",
    "@aws-lambda-powertools/parser": "2.32.0",
    "@aws-lambda-powertools/tracer": "2.32.0",
    "@aws-sdk/client-dynamodb": "3.1025.0",
    "@aws-sdk/client-eventbridge": "3.1025.0",
    "@aws-sdk/client-sqs": "3.1025.0",
    "@aws-sdk/lib-dynamodb": "3.1025.0",
    "@aws-sdk/util-dynamodb": "3.996.2",
    "@smithy/node-http-handler": "4.5.2",
    "axios": "1.14.0",
    "rxjs": "^7.8.1",
    "ulid": "3.0.2",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  }
}
