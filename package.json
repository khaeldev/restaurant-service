{
  "name": "restaurant-service",
  "version": "1.0.0",
  "description": "restaurant-service",
  "scripts": {
    "dev": "serverless offline start --stage dev --region us-east-1 --param=account=1 --param=OPENAI_API_KEY=1 --param=ANTHROPIC_API_KEY=1 --param=JWT_SECRET=1 --param=FARMERS_MARKET_API_URL=http://127.0.0.1:3000/dev/farmers-market/buy",
    "pkg": "serverless package --stage dev --region us-east-1 --param=account=1 --param=OPENAI_API_KEY=1 --param=ANTHROPIC_API_KEY=1 --param=JWT_SECRET=1 --param=FARMERS_MARKET_API_URL=http://127.0.0.1:3000/dev/farmers-market/buy",
    "deploy": "serverless deploy --stage dev --region us-east-1 --param=account=1 && npm run seed:dev",
    "deploy:prod": "serverless deploy --stage prod --region us-east-1 --param=account=1 && npm run seed:prod",
    "seed:dev": "serverless invoke -f seedData --stage dev --region us-east-1",
    "seed:prod": "serverless invoke -f seedData --stage prod --region us-east-1",
    "seed": "npm run seed:dev",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest --ci --detectOpenHandles --config=jest.config.json --passWithNoTests",
    "test:dev": "npm run lint --fix && npx jest --detectOpenHandles --config=jest.config.json --watch",
    "prepare": "husky",
    "logs:fc": "serverless logs --stage dev --region us-east-1 --function"
  },
  "engines": {
    "node": "22.19.0"
  },
  "devDependencies": {
    "@aws-sdk/types": "3.973.4",
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@commitlint/types": "20.4.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/aws-lambda": "8.10.161",
    "@types/jest": "30.0.0",
    "@types/node": "25.3.2",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "dotenv": "17.3.1",
    "esbuild": "0.27.3",
    "eslint": "10.0.2",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "serverless": "4.33.0",
    "serverless-offline": "^14.5.0",
    "serverless-prune-plugin": "2.1.0",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.31.0",
    "@aws-lambda-powertools/parser": "2.31.0",
    "@aws-lambda-powertools/tracer": "2.31.0",
    "@aws-sdk/client-dynamodb": "3.1000.0",
    "@aws-sdk/client-eventbridge": "3.1000.0",
    "@aws-sdk/lib-dynamodb": "3.1000.0",
    "@aws-sdk/util-dynamodb": "3.996.1",
    "@smithy/node-http-handler": "4.4.12",
    "ulid": "3.0.2",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  }
}
