# Restaurant Service Dashboard - Environment Variables Template
# Copy this file to .env.local and update with your values

# API Base URL - Required
# Point to your backend API server
# Development: http://localhost:3000 (if backend runs on same host)
# Production: set your API base URL (e.g. https://api.example.com)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_TOKEN_SECRET=tokenSecret
# Optional: API Timeout (in milliseconds)
# Default is 10000 (10 seconds)
# NEXT_PUBLIC_API_TIMEOUT=10000

# Optional: Enable debug logging
# Set to 'true' for verbose console output
# DEBUG=true

# Optional: Analytics
# Uncomment and configure if using Sentry, LogRocket, etc.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_ANALYTICS_ID=
